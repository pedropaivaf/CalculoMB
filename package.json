{
  "name": "calculadora-honorarios-contabeis",
  "version": "1.0.0",
  "description": "Calculadora de Honorários Contábeis",
  "main": "main.js",
  "scripts": {
    "create-icon": "node scripts/create-icon.js",
    "start": "electron --no-sandbox --disable-gpu .",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "express": "^4.19.2",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.calculadoraceo.honorarios",
    "productName": "Calculadora de Honorários",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "calculadora.html",
      "icon.ico",
      "node_modules/**/*"
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "shortcutName": "Calculadora de Honorários"
    }
  }
}
